{
  "manifest_version": 3,
  "name": "Voxi",
  "version": "0.1.0",
  "description": "リアルタイム音声文字起こし Chrome 拡張機能（日本語対応）",
  "permissions": [
    "scripting",
    "activeTab",
    "storage"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon_128.png",
    "32": "icons/icon_128.png",
    "48": "icons/icon_128.png",
    "128": "icons/icon_128.png"
  },
  "action": {
    "default_title": "Voxi",
    "default_icon": {
      "16": "icons/icon_128.png",
      "32": "icons/icon_128.png",
      "48": "icons/icon_128.png",
      "128": "icons/icon_128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["chunks/*", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": []
}
