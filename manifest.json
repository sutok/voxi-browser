{
  "manifest_version": 3,
  "name": "Voxi Browser",
  "version": "0.1.0",
  "description": "リアルタイム音声文字起こし Chrome 拡張機能（日本語対応）",
  "permissions": [
    "scripting",
    "activeTab"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Voxi Browser"
  },
  "web_accessible_resources": [
    {
      "resources": ["chunks/*", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": []
}
